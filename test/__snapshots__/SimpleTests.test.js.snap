      /* Variables (light) */
:root {
  --color-text: #40484f; --color-text-secondary: #606d76; --color-text-muted: #757575;
  --color-heading: #202931; --color-date: #202931; --color-accent: #ff6d1f;
  --color-link: #0095ff; --color-link-hover: #0c65a5;
