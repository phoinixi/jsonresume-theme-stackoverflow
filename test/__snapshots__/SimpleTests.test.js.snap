  <body>
    <a class="skip-to-content" href="#resume">Skip to content</a> <main id="resume" class="resume svelte-rssu9l"><header class="header clear svelte-10f9ycp"><!--[!--><div><h1 class="name svelte-10f9ycp">Richard Hendriks</h1> <h2 class="label svelte-10f9ycp">Programmer</h2></div> <span class="location svelte-10f9ycp"><span>2712 Broadway St,</span> <span>CA 94115,</span> <span>San Francisco,</span> <span>California</span> <span>(US)</span></span> <!--[!--><!----> <div class="contact svelte-121pvxs"><div class="contact-item svelte-121pvxs"><span class="fa-regular fa-envelope icon svelte-121pvxs"></span> <a class="hide-href-print" href="mailto:richard.hendriks@mail.com">richard.hendriks@mail.com</a></div> <div class="contact-item svelte-121pvxs"><span class="fa-solid fa-mobile-screen-button icon svelte-121pvxs"></span> <a class="hide-href-print" href="tel:(912) 555-4321">(912) 555-4321</a></div> <!--[!--></div><!----> <nav class="profiles svelte-10f9ycp" aria-label="Social profiles"><div class="item svelte-a76edc"><div class="username"><span class="fa-brands fa-twitter social svelte-a76edc" style="--brand-light: #00aced; --brand-dark: #00aced"></span> <span class="url"><a target="_blank" href="https://www.twitter.com"><span class="show-only-url-print">neutralthoughts</span></a></span></div></div><div class="item svelte-a76edc"><div class="username"><span class="fa-brands fa-soundcloud social svelte-a76edc" style="--brand-light: #ff3a00; --brand-dark: #ff3a00"></span> <span class="url"><a target="_blank" href="https://soundcloud.example.com/dandymusicnl"><span class="show-only-url-print">dandymusicnl</span></a></span></div></div></nav></header> <section class="section svelte-1lncexq"><header class="svelte-1lncexq"><h2 class="section-title svelte-1lncexq">Übersicht<!--[!--></h2></header> <section class="main-summary svelte-10f9ycp"><div><!--161124u--><p style="margin:0">Richard hails from Tulsa. He has earned degrees from the University of Oklahoma and Stanford. (Go Sooners and Cardinal!) Before starting Pied Piper, he worked for Hooli as a part time software developer. While his work focuses on applied information theory, mostly optimizing lossless compression schema of both the length-limited and adaptive variants, his non-work interests range widely, everything from quantum computing to chaos theory. He could tell you about it, but THAT would NOT be a “length-limited” conversation!</p><!----><!----></div></section><!----></section><!--[1--><section class="section svelte-1lncexq"><header class="svelte-1lncexq"><h2 class="section-title svelte-1lncexq">Kenntnisse<!--[!--></h2></header> <section class="skills-grid svelte-18p2gu6"><div class="skill-item svelte-18p2gu6"><h3 class="name svelte-18p2gu6">Web Development</h3> <div class="level master svelte-10tjtrd" role="meter" aria-label="Web Development level: Master" aria-valuemin="0" aria-valuemax="100" aria-valuenow="100"><em class="svelte-10tjtrd">Master</em> <div class="bar svelte-10tjtrd" aria-hidden="true"></div></div> <ul class="keywords svelte-1615qzb"><li class="svelte-1615qzb">HTML</li><li class="svelte-1615qzb">CSS</li><li class="svelte-1615qzb">Javascript</li></ul><!----></div><div class="skill-item svelte-18p2gu6"><h3 class="name svelte-18p2gu6">Compression</h3> <div class="level master svelte-10tjtrd" role="meter" aria-label="Compression level: Master" aria-valuemin="0" aria-valuemax="100" aria-valuenow="100"><em class="svelte-10tjtrd">Master</em> <div class="bar svelte-10tjtrd" aria-hidden="true"></div></div> <ul class="keywords svelte-1615qzb"><li class="svelte-1615qzb">Mpeg</li><li class="svelte-1615qzb">MP4</li><li class="svelte-1615qzb">GIF</li></ul><!----></div></section><!----></section><!--[2--><section class="section svelte-1lncexq"><header class="svelte-1lncexq"><h2 class="section-title svelte-1lncexq">Berufserfahrung<span class="item-count svelte-1lncexq">(1)</span></h2></header> <section id="work"><section class="timeline-item svelte-g3qng"><header class="clear svelte-g3qng"><div class="date"><span class="startDate">Dez. 2013</span> <span class="endDate">- Dez. 2014</span></div> <div class="header-left svelte-g3qng"><div class="position svelte-g3qng">CEO/President</div> <div class="company svelte-g3qng"><a target="_blank" href="http://piedpiper.example.com" class="svelte-g3qng">Pied Piper</a></div></div></header> <span class="location svelte-g3qng"><span class="fa-solid fa-location-dot"></span> Palo Alto, CA</span> <!--[!--><!----> <!--[!--> <div class="item svelte-g3qng"><div class="summary svelte-g3qng"><!--l05k9x--><p style="margin:0">Pied Piper is a multi-platform technology based on a proprietary universal compression algorithm that has consistently fielded high Weisman Scores™ that are not merely competitive, but approach the theoretical limit of lossless compression.</p><!----><!----></div> <ul class="highlights svelte-hqrtpf"><li class="svelte-hqrtpf"><!--1693yu--><p style="margin:0">Build an algorithm for artist to detect if their music was violating copy right infringement laws</p><!----><!----></li><li class="svelte-hqrtpf"><!--ky1nml--><p style="margin:0">Successfully won Techcrunch Disrupt</p><!----><!----></li><li class="svelte-hqrtpf"><!--apqo3d--><p style="margin:0">Optimized an algorithm that holds the current world record for Weisman Scores</p><!----><!----></li></ul><!----></div></section></section><!----></section><!--[3--><section class="section svelte-1lncexq"><header class="svelte-1lncexq"><h2 class="section-title svelte-1lncexq">Projekte<span class="item-count svelte-1lncexq">(1)</span></h2></header> <section id="projects"><section class="timeline-item svelte-g3qng"><header class="clear svelte-g3qng"><div class="date"><span class="startDate">Aug. 2016</span> <span class="endDate">- Aug. 2016</span></div> <div class="header-left svelte-g3qng"><div class="position svelte-g3qng">Miss Direction</div> <!--[!--></div></header> <!--[!--> <ul class="keywords svelte-1615qzb"><li class="svelte-1615qzb">GoogleMaps</li><li class="svelte-1615qzb">Chrome Extension</li><li class="svelte-1615qzb">Javascript</li></ul><!----> <span class="website svelte-fiykfy"><span class="fa-solid fa-up-right-from-square"></span> <a target="_blank" href="http://missdirection.example.com">http://missdirection.example.com</a></span><!----> <div class="item svelte-g3qng"><div class="summary svelte-g3qng"><!--1tmgzfl--><p style="margin:0">A mapping engine that misguides you</p><!----><!----></div> <ul class="highlights svelte-hqrtpf"><li class="svelte-hqrtpf"><!--12wudep--><p style="margin:0">Won award at AIHacks 2016</p><!----><!----></li><li class="svelte-hqrtpf"><!--11l6yir--><p style="margin:0">Built by all women team of newbie programmers</p><!----><!----></li><li class="svelte-hqrtpf"><!--s6g8d--><p style="margin:0">Using modern technologies such as GoogleMaps, Chrome Extension and Javascript</p><!----><!----></li></ul><!----></div></section></section><!----></section><!--[4--><section class="section svelte-1lncexq"><header class="svelte-1lncexq"><h2 class="section-title svelte-1lncexq">Ehrenamtliche Tätigkeiten<span class="item-count svelte-1lncexq">(1)</span></h2></header> <section id="volunteer"><section class="timeline-item svelte-g3qng"><header class="clear svelte-g3qng"><div class="date"><span class="startDate">Jan. 2012</span> <span class="endDate">- Jan. 2013</span></div> <div class="header-left svelte-g3qng"><div class="position svelte-g3qng">Teacher</div> <div class="organization svelte-g3qng"><a target="_blank" href="http://coderdojo.example.com/" class="svelte-g3qng">CoderDojo</a></div></div></header> <!--[!--> <!--[!--><!----> <!--[!--> <div class="item svelte-g3qng"><div class="summary svelte-g3qng"><!--j18lmw--><p style="margin:0">Global movement of free coding clubs for young people.</p><!----><!----></div> <ul class="highlights svelte-hqrtpf"><li class="svelte-hqrtpf"><!--1pp2it0--><p style="margin:0">Awarded 'Teacher of the Month'</p><!----><!----></li></ul><!----></div></section></section><!----></section><!--[5--><section class="section svelte-1lncexq"><header class="svelte-1lncexq"><h2 class="section-title svelte-1lncexq">Bildung<span class="item-count svelte-1lncexq">(1)</span></h2></header> <section id="education"><section class="timeline-item svelte-g3qng"><header class="clear svelte-g3qng"><div class="date"><span class="startDate">Juni 2011</span> <span class="endDate">- Jan. 2014</span></div> <div class="header-left svelte-g3qng"><div class="position svelte-g3qng">Bachelor Information Technology</div> <div class="institution svelte-g3qng"><a target="_blank" href="https://www.ou.edu/" class="svelte-g3qng">University of Oklahoma</a></div></div></header> <!--[!--> <!--[!--><!----> <ul class="courses svelte-1615qzb"><li class="svelte-1615qzb">DB1101 - Basic SQL</li><li class="svelte-1615qzb">CS2011 - Java Introduction</li></ul> <!--[!--><!----> <div class="item svelte-g3qng"><!--[!--> <!--[!--><!----></div></section></section><!----></section><!--[6--><section class="section svelte-1lncexq"><header class="svelte-1lncexq"><h2 class="section-title svelte-1lncexq">Auszeichnungen<span class="item-count svelte-1lncexq">(1)</span></h2></header> <section id="awards"><section class="timeline-item svelte-g3qng"><header class="clear svelte-g3qng"><!--[1--><div class="date svelte-g3qng">Nov. 2014</div> <div class="header-left svelte-g3qng"><div class="position svelte-g3qng">Digital Compression Pioneer Award</div> <div class="awarder svelte-g3qng"><!--[!-->Techcrunch</div></div></header> <!--[!--> <!--[!--><!----> <!--[!--> <div class="item svelte-g3qng"><div class="summary svelte-g3qng"><!--1nciraa--><p style="margin:0">There is no spoon.</p><!----><!----></div> <!--[!--><!----></div></section></section><!----></section><!--[7--><!--[!--><!--[8--><section class="section svelte-1lncexq"><header class="svelte-1lncexq"><h2 class="section-title svelte-1lncexq">Veröffentlichungen<span class="item-count svelte-1lncexq">(1)</span></h2></header> 